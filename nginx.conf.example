# nginx configuration for Work Calendar App
# Replace: your-domain.com, /path/to/WORK_CALENDAR_APP
#
# Setup steps (Ubuntu/Debian):
#   1. Install nginx:        sudo apt install nginx
#   2. Install certbot:      sudo apt install certbot python3-certbot-nginx
#   3. Copy this file:       sudo cp nginx.conf.example /etc/nginx/sites-available/work-calendar
#   4. Enable site:          sudo ln -s /etc/nginx/sites-available/work-calendar /etc/nginx/sites-enabled/
#   5. Get SSL certificate:  sudo certbot --nginx -d your-domain.com
#   6. Reload nginx:         sudo systemctl reload nginx

server {
    listen 80;
    server_name your-domain.com;
    # Redirect all HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name your-domain.com;

    ssl_certificate     /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Pass real client IP to Flask (required for rate limiting and audit logs)
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host              $host;

    location / {
        proxy_pass http://127.0.0.1:8000;
    }
}
